# Copy to .dev.vars (gitignored) for local `wrangler dev` / `vitest` runs.
# Test-mode only — CLAUDE.md forbids any real vendor secret here.

# Pepper mixed into the SHA-256 hash of bearer API tokens before they're
# stored in D1 (tenants_index.api_token_hash). Any random string works for
# local dev; rotate via `wrangler secret put` for deployed environments.
TOKEN_HASH_PEPPER=dev-only-pepper-change-me

# B1 money path — OPTIONAL. Leave BOTH unset for local dev/test: POST
# /checkout then returns a simulated (own-API) checkout session instead of a
# real Stripe one, and POST /webhooks/stripe accepts events without signature
# verification ("test-sim mode"). Wiring a REAL Stripe TEST key (never a live
# key) is an ACTIVATION.md step, done via `wrangler secret put`, not here.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# D1/D2/D6 admin surface (see src/admin/README.md) — bearer secret required
# on every /admin/* route (cross-tenant billing/support/ops data). Unset ->
# every /admin/* call 401s (fails closed, never open-by-default). Any random
# string works for local dev; rotate via `wrangler secret put ADMIN_TOKEN`
# for a deployed environment. Never a real production secret in this file.
ADMIN_TOKEN=dev-only-admin-token-change-me
