# Cloudflare Pages headers. Applies to every response from this site.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://agent-cold-email-api.yaakovscher.workers.dev; img-src 'self' data:; base-uri 'none'; frame-ancestors 'none'

# Machine-readable assets: allow any origin to fetch these for AEO/registry scans.
/llms.txt
  Access-Control-Allow-Origin: *
  Content-Type: text/plain; charset=utf-8

/openapi.yaml
  Access-Control-Allow-Origin: *
  Content-Type: application/yaml; charset=utf-8

/.well-known/mcp/server-card.json
  Access-Control-Allow-Origin: *
  Content-Type: application/json; charset=utf-8

# Shared Open Graph / Twitter card image (1200x630) referenced by every
# page's og:image/twitter:image meta tags — explicit Content-Type since
# social-card crawlers (not just browsers) fetch this directly.
/assets/og-image.png
  Content-Type: image/png
